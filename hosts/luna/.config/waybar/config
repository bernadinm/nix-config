{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": [
        "custom/voice-note",
        "custom/tailscale",
        "custom/bluetooth",
        "custom/wifi",
        "custom/power",
        "network",
        "cpu",
        "memory",
        "pulseaudio",
        "battery",
        "tray"
    ],

    "sway/workspaces": {
        "format": "{name}",
        "disable-scroll": false,
        "all-outputs": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 50
    },

    "clock": {
        "interval": 60,
        "format": "{:%a %b %d %Y  %H:%M}",
        "format-alt": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "interval": 2,
        "format": "CPU: {usage}%",
        "tooltip": true
    },

    "memory": {
        "interval": 10,
        "format": "RAM: {}%",
        "tooltip-format": "Used: {used:0.1f}G / {total:0.1f}G"
    },

    "network": {
        "interval": 5,
        "format-wifi": "{essid} ({signalStrength}%)",
        "format-ethernet": "ETH: {ipaddr}",
        "format-disconnected": "NET: Disconnected",
        "tooltip-format": "Interface: {ifname}\nIP: {ipaddr}/{cidr}\nGateway: {gwaddr}",
        "tooltip-format-wifi": "SSID: {essid}\nSignal: {signalStrength}%\nFrequency: {frequency}MHz\nIP: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    },

    "custom/tailscale": {
        "exec": "if systemctl is-active --quiet tailscaled && [ \"$(tailscale status --json 2>/dev/null | jq -r '.Self.Online' 2>/dev/null)\" = \"true\" ]; then echo 'TS: ON'; else echo 'TS: OFF'; fi",
        "interval": 10,
        "format": "{}",
        "tooltip": true,
        "exec-tooltip": "tailscale status 2>/dev/null | head -5 || echo 'Tailscale not running'",
        "on-click": "alacritty -e tailscale status"
    },

    "custom/bluetooth": {
        "exec": "if lsmod | grep -q btusb; then echo 'BT: ON'; else echo 'BT: OFF'; fi",
        "interval": 2,
        "format": "{}",
        "tooltip": true,
        "exec-tooltip": "if lsmod | grep -q btusb; then echo 'Bluetooth: Enabled (Super+Shift+B to toggle)'; else echo 'Bluetooth: Disabled (Super+Shift+B to toggle)'; fi",
        "on-click": "bash -c 'if lsmod | grep -q btusb; then sudo modprobe -r btusb && notify-send \"Bluetooth Disabled\" \"Hardware powered off\"; else sudo modprobe btusb && sudo systemctl restart bluetooth && notify-send \"Bluetooth Enabled\" \"Hardware ready\"; fi && sleep 0.5 && pkill -RTMIN+8 waybar'"
    },

    "custom/wifi": {
        "exec": "if nmcli radio wifi | grep -q enabled; then echo 'WiFi: ON'; else echo 'WiFi: OFF'; fi",
        "interval": 2,
        "format": "{}",
        "tooltip": true,
        "exec-tooltip": "if nmcli radio wifi | grep -q enabled; then nmcli -t -f active,ssid dev wifi | grep '^yes' | cut -d: -f2 || echo 'WiFi enabled, not connected'; else echo 'WiFi: Disabled (F10 airplane mode)'; fi"
    },

    "custom/power": {
        "exec": "if [ -f /sys/class/power_supply/BAT1/current_now ] && [ -f /sys/class/power_supply/BAT1/voltage_now ]; then CURRENT=$(cat /sys/class/power_supply/BAT1/current_now); VOLTAGE=$(cat /sys/class/power_supply/BAT1/voltage_now); if [ \"$CURRENT\" -gt 0 ] && [ \"$VOLTAGE\" -gt 0 ]; then echo \"PWR: $(echo \"scale=1; ($CURRENT * $VOLTAGE) / 1000000000000\" | bc)W\"; else echo 'PWR: 0.0W'; fi; else echo 'PWR: N/A'; fi",
        "interval": 2,
        "format": "{}",
        "tooltip": true,
        "exec-tooltip": "echo 'Click to open Power Monitor Dashboard'",
        "on-click": "alacritty -e bash ~/.power_monitor.sh"
    },

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {time}",
        "format-charging": "⚡{capacity}% {time}",
        "format-plugged": "AC: {capacity}%",
        "format-alt": "{capacity}%",
        "tooltip-format": "{timeTo} ({capacity}%)",
        "on-click": "alacritty -e sh -c 'sudo powertop; exec bash'"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "VOL: {volume}%",
        "format-bluetooth": "BT-AUD: {volume}%",
        "format-bluetooth-muted": "BT-AUD: MUTE",
        "format-muted": "VOL: MUTE",
        "on-click": "pavucontrol"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "custom/voice-note": {
        "exec": "if [ -f /tmp/voice_note_pid ]; then echo '🎙️ REC'; else echo ''; fi",
        "interval": 1,
        "signal": 9,
        "format": "{}",
        "tooltip": true,
        "exec-tooltip": "if [ -f /tmp/voice_note_pid ]; then echo 'Recording voice note... Press Super+V to stop'; else echo 'Press Super+V to start recording'; fi",
        "on-click": "bash ~/.voice_note.sh"
    }
}
